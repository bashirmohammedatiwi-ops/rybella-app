# انسخ إلى .env: cp .env.docker.example .env

APP_NAME=Rybella
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://YOUR_VPS_IP:8080
APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_TIMEZONE=Asia/Baghdad

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=rybella_db
DB_USERNAME=rybella_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

DB_ROOT_PASSWORD=CHANGE_ROOT_PASSWORD

# منفذ التطبيق (لوحة التحكم والـ API)
APP_PORT=8080

# منفذ MySQL على المضيف (للوصول من خارج Docker)
MYSQL_HOST_PORT=3307

CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_DOMAIN=

SANCTUM_STATEFUL_DOMAINS=localhost

FILESYSTEM_DISK=public
